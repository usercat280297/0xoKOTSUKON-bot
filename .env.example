DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
# External Postgres for Render/local, for example Neon or Supabase.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
PG_SSL_REJECT_UNAUTHORIZED=false

# Optional local Docker Postgres values used by docker-compose.production.yml.
POSTGRES_DB=ticket_bot
POSTGRES_USER=ticketbot
POSTGRES_PASSWORD=change-me
TICKET_TIMEZONE=Asia/Bangkok
TICKET_HOURS_START=21
TICKET_HOURS_END=24
DAILY_CHECKIN_LOG_CHANNEL_ID=

# Render sets PORT automatically. Leave blank for normal local runs.
PORT=
HEALTH_SERVER_ENABLED=false
HEALTH_HOST=0.0.0.0
HEALTH_CHECK_PATH=/healthz

# Steam Denuvo update monitor
STEAM_UPDATES_CHANNEL_ID=
STEAM_UPDATE_CURATOR_ID=26095454
STEAM_UPDATE_POLL_MINUTES=1
STEAM_UPDATE_BATCH_SIZE=120
# Optional: limit monitor to a subset of Denuvo titles, separated by |
STEAM_UPDATE_GAMES=
