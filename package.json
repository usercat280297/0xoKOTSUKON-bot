{
  "name": "0xokitsu-ticket-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord ticket bot with multi-panel dropdown routing and Postgres persistence",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "register:commands": "tsx src/scripts/registerCommands.ts",
    "register:commands:prod": "node dist/scripts/registerCommands.js",
    "db:init": "tsx src/scripts/applySchema.ts",
    "db:init:prod": "node dist/scripts/applySchema.js",
    "seed:steam-denuvo": "tsx src/scripts/seedSteamDenuvoBoard.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
